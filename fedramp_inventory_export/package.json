{
  "name": "fedramp-inventory-export",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Consolidated full-inventory + FedRAMP 20x/Rev5 compliance export (XLSX + CSV), built from a FedPy cloud-evidence run.",
  "scripts": {
    "export": "tsx src/cli.ts",
    "export:collect": "tsx src/cli.ts --collect",
