{
  "name": "fedramp-20x-tracker",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "ingest": "tsx server/ingest.ts",
    "dev:server": "PORT=4000 tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "build:client": "vite build --config client/vite.config.ts",
    "build": "npm run build:client",
    "start": "NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "backup": "tsx scripts/backup.ts",
    "restore": "tsx scripts/restore.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.7.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  }
}
