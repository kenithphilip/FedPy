{
  "name": "fedramp-20x-cloud-evidence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Read-only collector that captures AWS and GCP evidence for FedRAMP 20x KSIs.",
  "scripts": {
    "collect": "tsx core/orchestrator.ts",
    "verify": "tsx core/verify-cli.ts",
    "collect:bun": "bun run core/orchestrator.ts",
    "verify:bun": "bun run core/verify-cli.ts",
    "collect:deno": "deno run --allow-read --allow-env --allow-sys --allow-net --allow-write --allow-run core/orchestrator.ts",
    "verify:deno": "deno run --allow-read --allow-env --allow-sys --allow-run core/verify-cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-accessanalyzer": "^3.700.0",
    "@aws-sdk/client-acm": "^3.700.0",
    "@aws-sdk/client-app-mesh": "^3.700.0",
    "@aws-sdk/client-athena": "^3.700.0",
    "@aws-sdk/client-auto-scaling": "^3.700.0",
    "@aws-sdk/client-backup": "^3.700.0",
    "@aws-sdk/client-cloudformation": "^3.700.0",
    "@aws-sdk/client-cloudfront": "^3.700.0",
    "@aws-sdk/client-cloudtrail": "^3.700.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-codebuild": "^3.700.0",
    "@aws-sdk/client-codepipeline": "^3.700.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.700.0",
    "@aws-sdk/client-config-service": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-ec2": "^3.700.0",
    "@aws-sdk/client-ecr": "^3.700.0",
    "@aws-sdk/client-eks": "^3.700.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.700.0",
    "@aws-sdk/client-eventbridge": "^3.700.0",
    "@aws-sdk/client-firehose": "^3.700.0",
    "@aws-sdk/client-guardduty": "^3.700.0",
    "@aws-sdk/client-iam": "^3.700.0",
    "@aws-sdk/client-identitystore": "^3.700.0",
    "@aws-sdk/client-inspector2": "^3.700.0",
    "@aws-sdk/client-kms": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-network-firewall": "^3.700.0",
    "@aws-sdk/client-organizations": "^3.700.0",
    "@aws-sdk/client-rds": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-securityhub": "^3.700.0",
    "@aws-sdk/client-shield": "^3.700.0",
    "@aws-sdk/client-signer": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/client-sso-admin": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@aws-sdk/client-wafv2": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.700.0",
    "@google-cloud/asset": "^6.3.0",
    "@google-cloud/recommender": "^7.2.0",
    "@google-cloud/resource-manager": "^6.2.0",
    "@kubernetes/client-node": "^0.22.3",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "p-limit": "^6.2.0",
    "pino": "^9.5.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
