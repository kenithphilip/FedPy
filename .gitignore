# ─── Dependencies ────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Build output ────────────────────────────────────────────────
dist/
**/dist/
*.tsbuildinfo

# ─── Local state / generated evidence (never commit) ─────────────
# cloud-evidence run output (evidence JSON, summaries, manifests, signatures)
cloud-evidence/out/
out/*.json
out/*.md
out/*.tsr
manifest.json
manifest.sig
coverage-report.json
pva-run-summary.json
summaries/

# tracker SQLite database + WAL sidecars + backups, and dated evidence
# snapshot directories (data/prohibited-vendors-snapshot-YYYYMMDD/, etc.).
data/
# ...but the committed LOOP-W.W1 statutory-constant catalogs under
# cloud-evidence/data/ ARE version-controlled reference data, not runtime state.
# (Re-include the directory first so the specific files below can be un-ignored;
# the wildcard keeps the tracker DB + snapshot dirs ignored.)
!cloud-evidence/data/
cloud-evidence/data/*
!cloud-evidence/data/far-52-204-25-named-entities.json
!cloud-evidence/data/ndaa-1634-named-entities.json
!cloud-evidence/data/fascsa-orders.json
!cloud-evidence/data/ssdf-800-218-v1.1.json
!cloud-evidence/data/ssdf-800-218A-ipd.json
!cloud-evidence/data/ssdf-800-218A-final.json
# Curated extractor input (LOOP-T.T1) — version-controlled reference data, not
# runtime state. Re-include the scripts/data dir so the file below un-ignores.
!cloud-evidence/scripts/data/
!cloud-evidence/scripts/data/ssdf-ksi-mapping.json
# tracker/server/data/ holds the runtime SQLite DB (ignored) plus the committed
# NIST SP 800-53 Rev 5 catalog copy the tracker uses for server-side
# compensating-control id validation (LOOP-B.B4). Re-include the dir, keep the DB
# ignored, then un-ignore the catalog file.
!tracker/server/data/
tracker/server/data/*
!tracker/server/data/nist-r5-controls.generated.json
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.gz
backups/

# ─── Secrets / key material (NEVER commit) ───────────────────────
.env
.env.*
!.env.example
*.pem
*.key
signing-key.pem
signing-pub.pem
service-account*.json
gcp-credentials*.json

# ─── Upstream reference clone (separate FedRAMP FRMR git repo) ────
# /docs is a clone of the official FedRAMP FRMR repository, with its own .git.
# It is reference material the tooling reads, not part of this codebase.
# Anchored to repo root so cloud-evidence/docs/ (our analysis + generated
# registry) is still tracked.
/docs/

# ─── Agent / editor / OS noise ───────────────────────────────────
.claude/
.idea/
.vscode/
.DS_Store
*.log
coverage/
*.lcov
.eslintcache
.cache/

# NIST 800-53 r5 reference clone (separate repo, like /docs)
/nist-r5-data/

# ─── Research: cloned reference repos (analysis inputs, not our code) ─
# We clone external repos here to analyze them; the analysis reports under
# research/reports/ ARE tracked, but the raw clones/downloads are not.
/research/clones/
/research/downloads/

# ─── Account-specific data — NEVER commit (this is a PUBLIC repo) ─────
# Nothing that reveals which cloud accounts are scanned, or their outputs.
# Enforced by scripts/scan-account-data.sh (pre-commit hook + CI). See
# scripts/README.md.
#
# Local dev fork (its own git repo — not part of core history).
/FedPy/
# Local-only environment/company term blocklist read by the pre-commit hook.
# Kept out of git so the sensitive terms are never published. See scripts/README.md.
scripts/blocked-terms.local
# Real per-account run configs: only sanitized *.example.yaml templates are
# committed. (config.yaml — the tracked template — has one dot, so it is kept.)
cloud-evidence/config.*.yaml
!cloud-evidence/config.example.yaml
# fedramp_inventory_export — generated workbooks/CSVs + the account-specific
# access memo (real account id, SSO role, service-enablement posture).
fedramp_inventory_export/out/
fedramp_inventory_export/out-*/
fedramp_inventory_export/ACCESS-MEMO.md
# nonfed_pci_inventory_generator — code is tracked; real-account outputs, dumps,
# infra context, and account-coupled report subtools are not.
nonfed_pci_inventory_generator/output/
nonfed_pci_inventory_generator/cluster_reports/
nonfed_pci_inventory_generator/reference_outputs/
nonfed_pci_inventory_generator/context/
nonfed_pci_inventory_generator/crowe/
# Loose FIPS/scan report artifacts (entirely account-specific scan output).
/others_fips/
