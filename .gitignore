# ─── Dependencies ────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Build output ────────────────────────────────────────────────
dist/
**/dist/
*.tsbuildinfo

# ─── Local state / generated evidence (never commit) ─────────────
# cloud-evidence run output (evidence JSON, summaries, manifests, signatures)
cloud-evidence/out/
out/*.json
out/*.md
out/*.tsr
manifest.json
manifest.sig
coverage-report.json
pva-run-summary.json
summaries/

# tracker SQLite database + WAL sidecars + backups, and dated evidence
# snapshot directories (data/prohibited-vendors-snapshot-YYYYMMDD/, etc.).
data/
# ...but the committed LOOP-W.W1 statutory-constant catalogs under
# cloud-evidence/data/ ARE version-controlled reference data, not runtime state.
# (Re-include the directory first so the specific files below can be un-ignored;
# the wildcard keeps the tracker DB + snapshot dirs ignored.)
!cloud-evidence/data/
cloud-evidence/data/*
!cloud-evidence/data/far-52-204-25-named-entities.json
!cloud-evidence/data/ndaa-1634-named-entities.json
!cloud-evidence/data/fascsa-orders.json
!cloud-evidence/data/ssdf-800-218-v1.1.json
# Curated extractor input (LOOP-T.T1) — version-controlled reference data, not
# runtime state. Re-include the scripts/data dir so the file below un-ignores.
!cloud-evidence/scripts/data/
!cloud-evidence/scripts/data/ssdf-ksi-mapping.json
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.gz
backups/

# ─── Secrets / key material (NEVER commit) ───────────────────────
.env
.env.*
!.env.example
*.pem
*.key
signing-key.pem
signing-pub.pem
service-account*.json
gcp-credentials*.json

# ─── Upstream reference clone (separate FedRAMP FRMR git repo) ────
# /docs is a clone of the official FedRAMP FRMR repository, with its own .git.
# It is reference material the tooling reads, not part of this codebase.
# Anchored to repo root so cloud-evidence/docs/ (our analysis + generated
# registry) is still tracked.
/docs/

# ─── Agent / editor / OS noise ───────────────────────────────────
.claude/
.idea/
.vscode/
.DS_Store
*.log
coverage/
*.lcov
.eslintcache
.cache/

# NIST 800-53 r5 reference clone (separate repo, like /docs)
/nist-r5-data/

# ─── Research: cloned reference repos (analysis inputs, not our code) ─
# We clone external repos here to analyze them; the analysis reports under
# research/reports/ ARE tracked, but the raw clones/downloads are not.
/research/clones/
/research/downloads/
